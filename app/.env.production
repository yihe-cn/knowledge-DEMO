# 生产/镜像构建（npm run build）使用的环境变量。
# Vite 默认 build 走 production mode，只读 .env / .env.production，不读 .env.development。

# 同源：前端由 FastAPI 同进程托管，API 走相对路径 /api/*
VITE_API_BASE=

# Demo 模式建议留空，且容器侧也不设 INTERNAL_TOKEN，跳过 token 校验。
# 如果要开校验：把这里设成 demo-token，run 时也加 -e INTERNAL_TOKEN=demo-token
VITE_INTERNAL_TOKEN=
