# LLM 提供商（任何 OpenAI 兼容接口都可以）
# DeepSeek 示例：
OPENAI_API_KEY=your_openai_compatible_api_key
OPENAI_BASE_URL=https://api.wenwen-ai.com/v1
MODEL_NAME=gemini-3.5-flash

# 通义千问（兼容模式）示例：
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MODEL_NAME=qwen-plus

# 智谱 GLM 示例：
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# MODEL_NAME=glm-4

ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173
TEMPERATURE=0.6

# ── RAG 栈（docker-compose 默认值匹配）──────────────────────────
MYSQL_DSN=mysql+aiomysql://simugo:simugo@127.0.0.1:3306/simugo_kb
MYSQL_DSN_SYNC=mysql+pymysql://simugo:simugo@127.0.0.1:3306/simugo_kb
REDIS_URL=redis://127.0.0.1:6379/0
MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION=kb_chunks
MILVUS_DIM=1024

# Embedding：默认硅基流动 BGE-M3
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# KP 抽取（留空则复用 MODEL_NAME）
KP_EXTRACT_MODEL=
KP_EXTRACT_BATCH_SIZE=8
KP_DEDUPE_THRESHOLD=0.85

# 内部 API 鉴权：留空 = 开发模式不校验；生产必须设置一个长随机串
# 前端通过 VITE_INTERNAL_TOKEN 注入到请求头 X-Internal-Token
INTERNAL_TOKEN=
