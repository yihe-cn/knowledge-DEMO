{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "simugo-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "app", "run", "dev"],
      "port": 5173
    },
    {
      "name": "simugo-admin",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "admin", "run", "dev"],
      "port": 5174
    },
    {
      "name": "simugo-server",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "--directory", "server", "uvicorn", "app.main:app", "--port", "8000"],
      "port": 8000
    }
  ]
}
